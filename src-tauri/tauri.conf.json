{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codex+++",
  "version": "0.1.0-alpha.2",
  "identifier": "app.forgedesk.desktop",
  "build": {
    "beforeDevCommand": "pnpm.cmd dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm.cmd build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "codex+++",
        "label": "main",
        "width": 1480,
        "height": 920,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "worker-src": "'self' blob:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "Independent Codex desktop client",
    "longDescription": "codex+++ is an independent open-source desktop client for Codex CLI."
  }
}
